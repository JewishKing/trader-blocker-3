{
    "manifest_version": 3,
    "name": "FocusGuard Deriv Bridge",
    "version": "1.0",
    "description": "Custom price alerts for Deriv TradingView charts to unlock FocusGuard.",
    "permissions": [
        "storage",
        "activeTab",
        "scripting"
    ],
    "host_permissions": [
        "*://*.deriv.com/*",
        "*://*.deriv.app/*",
        "http://localhost:51700/*"
    ],
    "action": {
        "default_popup": "popup.html"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle",
            "all_frames": true
        }
    ]
}